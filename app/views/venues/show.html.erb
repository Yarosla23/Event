<div class="w-7/8 md:w-[73%] mx-auto m-4 p-6 bg-blue-200 dark:bg-gray-800 shadow-lg rounded-3xl">

  <h1 class="text-4xl text-center mt-2 mb-10 font-bold text-blue-800 dark:text-gray-100 leading-tight "><%= @venue.name %></h1>

<div class="flex flex-col xl:flex-row gap-6">
  <div class="relative md:w-2/3 mx-4">
    <%= render 'venues/show/slider' %>
  </div>

  <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 max-w-lg mx-auto">
    <%= render 'venues/show/info' %>
  </div>
</div>
<div class="flex flex-col lg:flex-row gap-6 mt-6">
  <div class="flex-1 bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 lg:w-2/3">
    <p class="mt-2 text-gray-600 dark:text-gray-300 text-lg whitespace-pre-line">
      <%= @venue.description %>
    </p>
  </div>

  <div class="flex-2 bg-white dark:bg-gray-800 p-6 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 space-y-2 lg:w-1/3">
    <%= render 'venues/show/ticket' %>
  </div>
</div>

  <div class="mt-6 bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border border-gray-200 dark:border-gray-700">
    <h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4">Документы и лицензии</h3>
    <p class="text-gray-700 dark:text-gray-300 whitespace-pre-line"><%= @venue&.information&.document.presence || "Документы и лицензии не указаны."%></p>
  </div>

  <div class="mt-6 bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border border-gray-200 dark:border-gray-700">
    <h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200  mb-4">Дополнительная информация</h3>
    <p class="text-gray-700 dark:text-gray-300 whitespace-pre-line"><%= @venue&.information&.description.presence || "Дополнительная информация отсутствует."%></p>
  </div>

  <div class="mt-6 flex justify-between items-center">
    <%= form_with url: venue_path(@venue), method: :delete, data: { confirm: 'Вы уверены?' }, class: "inline-block" do %>
      <%= submit_tag 'Удалить', class: "px-4 py-2 bg-red-500 text-white font-semibold rounded hover:bg-red-600 transition" %>
    <% end %>
    <div class="space-x-4">
      <%= link_to 'Редактировать', edit_venue_path(@venue), class: "px-4 py-2 bg-blue-500 text-white font-semibold rounded hover:bg-blue-600 transition" %>
      <%= link_to 'Назад', venues_path, class: "px-4 py-2 bg-gray-500 text-white font-semibold rounded hover:bg-gray-600 transition" %>
    </div>
  </div>
</div>
    <%= render 'venues/show/reviews', venue: @venue, reviews: @reviews %>
