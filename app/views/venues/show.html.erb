<h1><%= @venue.name %></h1>

<p><strong>Тип площадки:</strong> <%= @venue.venue_type %></p>
<p><strong>Местоположение:</strong> <%= @venue.location&.address %></p>
<p><strong>Цена:</strong> <%= @venue.price&.amount %> <%= @venue.price&.currency %></p>

<h3>Удобства:</h3>
<ul>
  <% @venue.amenities.each do |amenity| %>
    <li><%= amenity.name %></li>
  <% end %>
</ul>

<h3>Типы мероприятий:</h3>
<ul>
  <% @venue.event_types.each do |event_type| %>
    <li><%= event_type.name %></li>
  <% end %>
</ul>

<h3>Отзывы:</h3>
<ul>
  <% @venue.reviews.each do |review| %>
    <li><%= review.content %> — <%= review.rating %>/5</li>
  <% end %>
</ul>

<%= link_to 'Редактировать', edit_venue_path(@venue), class: 'btn btn-warning' %>
<%= link_to 'Назад', venues_path, class: 'btn btn-secondary' %>
