<div class="p-2 md:p-3  bg-gray-50 dark:bg-gray-800 shadow-md rounded-lg border border-gray-200 dark:border-gray-700 my-3 md:my-6">
  <h3 class="text-lg font-semibold text-gray-900 dark:text-white m-4">Основная информация об мероприятии</h3>
  <div class="columns-1 md:columns-2 gap-6">

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :name, 
        label: "Название площадки") 
      %>
    </div>

    <div class="field mb-4">
      <%= render Ui::SelectFieldComponent.new(
        form: form,
        field_name: :venue_type,
        label: "Тип площадки",
        options: Event::TYPES,
        include_blank: 'Выберите тип площадки',
        input_class: "custom-class"
      ) %>
    </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :area,
        label: "Площадь",
        type: "number", 
        step: 0.01
      ) %>
    </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :website,
        label: "Сайт",
      ) %>
    </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :email,
        label: "Электронная почта",
      ) %>
    </div>
    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :phone,
        label: "Телефон",
      ) %>
    </div>


    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :address,
        label: "Адрес",
      ) %>
    </div>


    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :max_participants,
        label: "Максимальное количество гостей",
        type: "number", 
        step: 1
      ) %>
    </div>
  </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :description,
        label: "Описание",
        type: "text_area",
        input_class: "whitespace-pre-wrap "
      ) %>
    </div>
          <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :details,
        label: "Дополнительные возможности по размещению",
        type: "text_area",
        input_class: "whitespace-pre-wrap "
      ) %>
    </div>
</div>
