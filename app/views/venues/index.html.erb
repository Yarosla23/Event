<%= link_to 'Создать новую площадку', new_venue_path, class: 'btn btn-primary' %>

<table class="table table-bordered mt-3">
  <thead>
    <tr>
      <th>Название</th>
      <th>Тип</th>
      <th>Местоположение</th>
      <th>Цена</th>
      <th>Действия</th>
    </tr>
  </thead>
  <tbody>
    <% @venues.each do |venue| %>
      <tr>
        <td><%= venue.name %></td>
        <td><%= venue.venue_type %></td>
        <td><%= venue.location&.address %></td>
        <td><%= venue.price&.amount %> <%= venue.price&.currency %></td>
        <td>
          <%= link_to 'Посмотреть', venue_path(venue), class: 'btn btn-info' %>
          <%= link_to 'Редактировать', edit_venue_path(venue), class: 'btn btn-warning' %>
          <%= link_to 'Удалить', venue_path(venue), method: :delete, data: { confirm: 'Вы уверены?' }, class: 'btn btn-danger' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
