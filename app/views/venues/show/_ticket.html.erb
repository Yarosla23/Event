  <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Информация о зале</h3>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Wi-Fi</span>
      <p class="<%= @venue.facility.wifi ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.wifi ? 'Есть' : 'Нет' %>
      </p>
    </div>

    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Кондиционер</span>
      <p class="<%= @venue.facility.air_conditioning ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.air_conditioning ? 'Есть' : 'Нет' %>
      </p>
    </div>

    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Аудиовизуальное оборудование</span>
      <p class="<%= @venue.facility.audio_visual_equipment ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.audio_visual_equipment ? 'Есть' : 'Нет' %>
      </p>
    </div>

    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Парковка</span>
      <p class="<%= @venue.facility.parking ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.parking ? 'Есть' : 'Нет' %>
      </p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Доступ для инвалидов</span>
      <p class="<%= @venue.facility.disabled_access ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.disabled_access ? 'Есть' : 'Нет' %>
      </p>
    </div>

    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Кухня</span>
      <p class="<%= @venue.facility.kitchen ? 'text-green-500' : 'text-red-500' %>">
        <%= @venue.facility.kitchen ? 'Есть' : 'Нет' %>
      </p>
    </div>

    <div>
      <span class="font-semibold text-gray-700 dark:text-gray-300">Количество туалетов</span>
      <p><%= @venue.facility.toilets_count %></p>
    </div>
  </div>

  <div class="mb-6">
    <span class="font-semibold text-gray-700 dark:text-gray-300">Другие удобства</span>
    <p><%= @venue.facility.other_facilities.present? ? @venue.facility.other_facilities : 'Нет дополнительных удобств' %></p>
  </div>
