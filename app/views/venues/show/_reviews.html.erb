<h2 class="text-3xl font-bold mb-4 text-center">Отзывы</h2>

<div class="flex justify-center">
  <div class="w-1/2">
<% @reviews.first(3).each do |review| %> <!-- Показываем только 3 первых отзыва -->
  <div class="bg-blue-100 p-4 rounded-2xl shadow-md mb-4 review-card flex flex-col justify-between">
    <div class="flex items-center mb-2">
      <% if avatar = review.user.profile&.avatar_url %>
        <img src="<%= avatar %>" class="w-8 h-8 rounded-full flex items-center justify-center text-white" alt="Аватар" />
      <% else %>
        <div class="w-8 h-8 rounded-full bg-blue-700 flex items-center justify-center text-white">
          <%= review.user.email[0] %> 
        </div>
      <% end %>

      <p class="ml-4 font-semibold text-lg">
        <%= link_to review.user.profile.last_name, user_profile_path(review.user) %>
      </p>
      <p class="ml-2 font-semibold text-lg">
        <%= link_to review.user.profile.first_name, user_profile_path(review.user) %>
      </p>

      <p class="ml-auto text-sm text-gray-500">
        <div class="flex items-center mb-2">
          <% 1.upto(5) do |i| %>
            <span class="<%= i <= review.rating ? 'text-yellow-400' : 'text-gray-300' %> text-3xl">
              ★
            </span>
          <% end %>
        </div>
      </p>
    </div>

    <p class="text-gray-700 mt-2"><%= review.content %></p>
    <div class="mt-auto flex justify-end text-sm text-gray-500">
      <%= review.created_at.strftime("%d.%m.%Y") %>
    </div>

  </div>
<% end %>


    <!-- Показываем оставшиеся отзывы с классом hidden -->
    <div id="more_reviews" class="hidden">
      <% @reviews.drop(3).each do |review| %> <!-- Остальные отзывы -->
        <div class="bg-blue-100 p-4 rounded-lg shadow-md mb-4 review-card">
          <div class="flex items-center mb-2">
            <div class="w-8 h-8 rounded-full bg-gray-300 flex items-center justify-center text-white">
              <%= review.user.email[0] %>
            </div>
            <p class="ml-4 font-semibold text-lg"><%= review.user.email %></p>
            <p class="ml-auto text-sm text-gray-500"><%= review.created_at.strftime("%d.%m.%Y") %></p>
          </div>
          <div class="flex items-center mb-2">
            <% 1.upto(5) do |i| %>
              <span class="<%= i <= review.rating ? 'text-yellow-400' : 'text-gray-300' %> text-2xl">
                ★
              </span>
            <% end %>
            <span class="ml-2 text-sm text-gray-500"><%= review.rating %>/5</span>
          </div>
          <p class="text-gray-700 mt-2"><%= review.content %></p>
        </div>
      <% end %>
    </div>

    <% if @venue.reviews.count > 3 %>
      <button id="show_more_reviews" class="mt-4 text-blue-500">
        Посмотреть все комментарии
      </button>
    <% end %>
  </div>
</div>

<% if user_signed_in? %>
  <h3>Добавить отзыв</h3>
  <%= form_with model: [@venue, @venue.reviews.new], local: true do |form| %>
    <div class="flex items-center space-x-1 rtl:space-x-reverse">
      <% 1.upto(5) do |i| %>
        <button type="button" data-value="<%= i %>" 
          class="star text-gray-300 hover:text-yellow-400 focus:text-yellow-400 text-2xl transition duration-150"
          aria-label="Рейтинг <%= i %>">
          ★
        </button>
      <% end %>
      <input type="hidden" name="review[rating]" id="review_rating" value="0">
    </div>

    <div>
      <%= form.label :content, 'Ваш отзыв' %>
      <%= form.text_area :content, required: true %>
    </div>
    <div>
      <%= form.submit 'Добавить' %>
    </div>
  <% end %>
<% else %>
  <p>Пожалуйста, <%= link_to 'войдите', new_user_session_path %>, чтобы оставить отзыв.</p>
<% end %>

<script>
  document.addEventListener('turbo:load', () => {
    // Логика для показа скрытых отзывов
    const showMoreButton = document.querySelector('#show_more_reviews');
    const moreReviews = document.querySelector('#more_reviews');

    if (showMoreButton) {
      showMoreButton.addEventListener('click', () => {
        moreReviews.classList.remove('hidden'); // Показываем остальные отзывы
        showMoreButton.style.display = 'none'; // Прячем кнопку "Посмотреть все комментарии"
      });
    }

    // Стрелки для оценки
    const stars = document.querySelectorAll('.star');
    const ratingInput = document.querySelector('#review_rating');

    stars.forEach((star, index) => {
      star.addEventListener('mouseover', () => {
        highlightStars(index);
      });

      star.addEventListener('click', () => {
        setRating(index);
      });
    });

    function highlightStars(index) {
      stars.forEach((star, i) => {
        star.classList.toggle('text-yellow-400', i <= index);
        star.classList.toggle('text-gray-300', i > index);
      });
    }

    function setRating(index) {
      ratingInput.value = index + 1; // Устанавливаем рейтинг
    }
  });
</script>
