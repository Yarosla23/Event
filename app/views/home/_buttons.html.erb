<div id="buttons" class="flex flex-col items-center mt-10 py-12 space-y-12">

  <div class="bg-blue-100 dark:bg-blue-800 w-3/4 max-w-4xl p-12 pb-0 rounded-[50px] md:rounded-[100px] shadow-lg transform transition-transform hover:scale-105 flex flex-col justify-between mx-auto">
    <h2 class="text-2xl md:text-5xl font-semibold text-blue-900 dark:text-blue-100 mb-6 text-center md:text-left">
      Найди свою встречу или идеальную площадку для мероприятий
    </h2>
    <div class="flex items-center justify-between mb-6 space-x-6">
      <button class="w-auto bg-blue-500 text-white py-4 px-8 md:py-6 md:px-12 rounded-full text-lg md:text-2xl font-semibold hover:bg-blue-600 dark:bg-blue-600 dark:hover:bg-blue-500 transition duration-300">
        Вход для участников и организаторов.
      </button>

      <%= image_tag 'icons/people.svg', class: "w-20 h-20 md:w-28 md:h-24 flex-shrink-0" %>
    </div>
    <div class="bg-blue-900 w-3/4 mx-auto p-4 rounded-t-[50px] md:rounded-t-[100px] shadow-lg mt-auto">
      <p class="text-white text-center text-xs md:text-base">
        Присоединяйся, создавай, наслаждайся и находи новых друзей! 🎉
      </p>
    </div>
  </div>

  <div class="bg-green-100 dark:bg-green-800 w-3/4 max-w-4xl p-12 pb-0 rounded-[50px] md:rounded-[100px] shadow-lg transform transition-transform hover:scale-105 flex flex-col justify-between mx-auto">
    <h2 class="text-2xl md:text-5xl font-semibold text-green-900 dark:text-green-100 mb-6 text-center md:text-left">
      Делись своим пространством — дари радость
    </h2>
    <div class="flex items-center justify-between mb-6 space-x-6">
      <button class="w-auto bg-lime-600 text-white py-4 px-8 md:py-6 md:px-12 rounded-full text-lg md:text-2xl font-semibold hover:bg-green-600 dark:bg-lime-500 dark:hover:bg-lime-400 transition duration-300">
       Вход для арендодателей.
      </button>
      <%= image_tag 'icons/park.svg', class: "w-20 h-20 md:w-34 md:h-24 flex-shrink-0" %>
    </div>
    <div class="bg-green-900 w-3/4 mx-auto p-4 rounded-t-[50px] md:rounded-t-[100px] shadow-lg mt-auto">
      <p class="text-white px-2 text-center text-xs md:text-sm">
        Преврати свою площадку в место, которое вдохновляет, объединяет и дарит людям счастье! 🎉
      </p>
    </div>
  </div>

</div>

<!-- Медиазапросы для уменьшения элементов на мобильных устройствах -->
<style>
  @media (max-width: 768px) {
    #buttons .bg-blue-100,
    #buttons .bg-green-100 {
      width: 100%; /* Уменьшаем ширину блоков на мобильных */
      padding: 8px; /* Уменьшаем padding */
    }
    #buttons .text-2xl {
      font-size: 1.25rem; /* Уменьшаем шрифт заголовков */
    }
    #buttons .text-lg {
      font-size: 1rem; /* Уменьшаем шрифт кнопок */
    }
    #buttons .w-20 {
      width: 3rem; /* Уменьшаем размеры иконок */
      height: 3rem; /* Уменьшаем размеры иконок */
    }
    #buttons .w-28 {
      width: 5.25rem; /* Уменьшаем размеры иконок на мобильных */
      height: 4.25rem; /* Уменьшаем размеры иконок на мобильных */
    }
    #buttons .w-34 {
      width: 7rem; /* Уменьшаем размеры иконок на мобильных */
      height: 5.25rem; /* Уменьшаем размеры иконок на мобильных */
    }
  }
</style>
