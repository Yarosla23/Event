<div class="p-2 md:p-3  bg-gray-50 dark:bg-gray-800 shadow-md rounded-lg border border-gray-200 dark:border-gray-700 my-3 md:my-6">
  <h3 class="text-lg font-semibold text-gray-900 dark:text-white m-4">Основная информация об мероприятии</h3>
  <div class="columns-1 md:columns-2 gap-6">

    <!-- Колонка 1 -->
    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :name, 
        label: "Название мероприятия") 
      %>
    </div>

    <div class="field mb-4">
      <%= render Ui::SelectFieldComponent.new(
        form: form,
        field_name: :event_type,
        label: "Тип мероприятия",
        options: Event::TYPES,
        include_blank: 'Выберите тип мероприятия',
        input_class: "custom-class"
      ) %>
    </div>
    
    <div class="field mx-3 mb-4">
      <%= form.label :start_time, "Время начала", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= form.text_field :start_time, type: "datetime-local", value: form.object.start_time&.strftime("%Y-%m-%dT%H:%M"), class: "block w-full p-2.5 bg-white border border-gray-300 text-gray-900 text-sm rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
      <% if form.object.errors[:start_time].any? %>
        <div class="text-sm text-red-500">
          <%= form.object.errors[:start_time].join(', ') %>
        </div>
      <% end %>
    </div>

    <div class="field mx-3 mb-4">
      <%= form.label :end_time, "Время окончания", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= form.text_field :end_time, type: "datetime-local", value: form.object.end_time&.strftime("%Y-%m-%dT%H:%M"), class: "block w-full p-2.5 bg-white border border-gray-300 text-gray-900 text-sm rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
      <% if form.object.errors[:end_time].any? %>
        <div class="text-sm text-red-500">
          <%= form.object.errors[:end_time].join(', ') %>
        </div>
      <% end %>
    </div>

    <!-- Колонка 2 -->
    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :location,
        label: "Местоположение",
      ) %>
    </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :location_link,
        label: "Ссылка на локацию",
      ) %>
    </div>

    <div class="field mb-4">
      <%= render Ui::InputFieldComponent.new(
        form: form,
        field_name: :event_format,
        label: "Формат мероприятия",
      ) %>
    </div>

<div class="field mb-4">
  <%= render Ui::InputFieldComponent.new(
    form: form,
    field_name: :description,
    label: "Описание",
    type: "text_area",
    input_class: "whitespace-pre-wrap "
  ) %>
</div>
<div class="field mb-4">
  <div class="relative inline-block w-full">
    <div 
      class="multiselect-container w-full border border-gray-300 rounded-lg cursor-pointer p-2 hover:bg-gray-50"
      onclick="toggleDropdown()">
      <span id="selected-tags" class="text-gray-700">
        <%= @selected_tags.any? ? @selected_tags.join(", ") : "Выберите типы мероприятий" %>
      </span>
      <svg class="w-5 h-5 absolute top-3 right-3 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
    <div id="dropdown" class="hidden absolute z-10 bg-white border border-gray-300 rounded-lg shadow-lg w-full mt-1">
      <div class="max-h-48 overflow-y-auto">
        <% Event::TYPES.each do |key| %>
          <div 
            data-key="<%= key %>"
            class="dropdown-item px-4 py-2 hover:bg-gray-100 cursor-pointer <%= 'text-blue-500 font-semibold' if @selected_tags.include?(key) %>">
            <span class="text-gray-700">
              <%= key %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%= form.hidden_field :tags, id: "hidden-tags", value: @selected_tags.join(",") %>
</div>
  </div>
  </div>

<script>
  document.addEventListener('turbo:load', () => {
    const dropdown = document.getElementById("dropdown");
    const dropdownItems = document.querySelectorAll(".dropdown-item");
    const hiddenField = document.getElementById("hidden-tags");
    const selectedTagsDisplay = document.getElementById("selected-tags");

    // Функция для обновления отображения выбранных тегов
    function updateSelectedTagsDisplay() {
      const selectedTags = hiddenField.value ? hiddenField.value.split(",") : [];
      if (selectedTags.length > 0) {
        selectedTagsDisplay.textContent = selectedTags.join(", ");
      } else {
        selectedTagsDisplay.textContent = "Выберите типы мероприятий";
      }
    }

    window.toggleDropdown = () => {
      dropdown.classList.toggle("hidden");
    };

    // Обработка выбора элементов
    dropdownItems.forEach(item => {
      item.addEventListener("click", () => {
        const key = item.getAttribute("data-key");
        let selectedTags = hiddenField.value ? hiddenField.value.split(",") : [];

        if (selectedTags.includes(key)) {
          selectedTags = selectedTags.filter(tag => tag !== key); // Удалить из выбранных
          item.querySelector("span").classList.remove("text-blue-500", "font-semibold");
          item.querySelector("span").classList.add("text-gray-700");
        } else {
          selectedTags.push(key); // Добавить к выбранным
          item.querySelector("span").classList.add("text-blue-500", "font-semibold");
          item.querySelector("span").classList.remove("text-gray-700");
        }

        hiddenField.value = selectedTags.join(",");
        updateSelectedTagsDisplay();
      });
    });

    // Обновление отображения при загрузке страницы
    updateSelectedTagsDisplay();
  });
</script>

<style>
  .dropdown-item span {
    transition: color 0.2s, font-weight 0.2s;
  }

  .dropdown-item span.text-blue-500 {
    color: #3b82f6; /* Голубой цвет */
    font-weight: bold;
  }
</style>
