<div class="w-full lg:w-3/4 flex justify-center py-8 bg-gray-50 dark:bg-gray-900 min-h-screen relative overflow-hidden">
  <!-- Animated Background with more dynamic colors and movement -->
  <div class="absolute inset-0 bg-gradient-to-r from-pink-300 via-blue-200 to-pink-300 animate-gradient-background"></div>

  <!-- Floating Bubbles Animation -->
  <div class="absolute inset-0 flex justify-center items-center">
    <div id="bubbles-container" class="bubbles-container"></div>
  </div>

  <!-- Profile container with responsive width: full width on small screens, 2/3 width on large screens -->
  <div class="bg-white dark:bg-gray-900 rounded-lg shadow-xl text-gray-800 dark:text-white relative z-10">
    <!-- Верхняя часть профиля -->
    <div class="relative">
      <!-- Обложка с выбором цвета -->

<%= turbo_stream.replace "profile-cover" do %>
  <div id="profile-cover" class="h-48 rounded-t-lg" style="background-color: <%= @profile.cover_color %>;">
    <%= form_with url: user_profile_path(@user), method: :patch, data: { turbo_frame: 'profile-cover' }, class: 'absolute top-2 right-2' do |f| %>
      <label for="cover_color" class="block text-white text-sm font-medium">Цвет:</label>
      <%= f.color_field :cover_color, value: @profile.cover_color || '#4f46e5', class: 'rounded-full w-10 h-10 border-none shadow-md cursor-pointer' %>
      <button type="submit" class="mt-2 bg-white text-indigo-600 px-2 py-1 rounded-full shadow hover:bg-gray-100">Сохранить</button>
    <% end %>
  </div>
<% end %>

      <!-- Аватар -->
      <div class="absolute -bottom-20 left-1/2 transform -translate-x-1/2">
        <% if @profile.avatar.present? %>
          <img src="<%= @profile.avatar_url %>" alt="Аватар" class="w-40 h-40 object-cover rounded-full border-4 border-white shadow-lg" />
        <% else %>
          <div class="w-40 h-40 flex items-center justify-center rounded-full bg-gray-200 dark:bg-gray-700 border-4 border-gray-300 dark:border-gray-800 shadow-lg">
            <span class="text-gray-500 dark:text-gray-400 text-sm">Нет фото</span>
          </div>
        <% end %>
        <div class="absolute -bottom-3 -right-3 bg-indigo-600 p-2 rounded-full shadow-md hover:bg-indigo-500 cursor-pointer">
          <a href="<%= edit_user_profile_path(@user) %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L7 21H3v-4L16.732 3.732z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Имя и статус -->
    <div class="text-center mt-24">
      <h1 class="text-2xl font-extrabold"><%= @profile.first_name || "Иван" %> <%= @profile.last_name || "Иванов" %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 italic">"Люблю путешествия и вечеринки!"</p>
    </div>

    <!-- Информация профиля -->
    <div class="mt-8 grid gap-6 sm:grid-cols-2 px-8">
      <div class="flex items-center">
        <span class="material-icons text-indigo-500 dark:text-indigo-400 mr-2">cake</span>
        <p><strong>Дата рождения:</strong> <%= @profile.birthday_date || "Не указано" %></p>
      </div>
      <div class="flex items-center">
        <span class="material-icons text-indigo-500 dark:text-indigo-400 mr-2">call</span>
        <p><strong>Телефон:</strong> <%= @profile.phone || "+711-111-11-111" %></p>
      </div>
      <div class="flex items-center">
        <span class="material-icons text-indigo-500 dark:text-indigo-400 mr-2">location_on</span>
        <p><strong>Город:</strong> <%= @profile.city || "Москва" %></p>
      </div>
      <div class="flex items-center">
        <span class="material-icons text-indigo-500 dark:text-indigo-400 mr-2">male</span>
        <p><strong>Пол:</strong> <%= @profile.gender == "male" ? "Мужской" : "Женский" %></p>
      </div>
    </div>

    <!-- Описание -->
    <div class="mt-6 px-8">
      <label class="block mb-2 text-lg font-bold text-gray-700 dark:text-gray-300">О себе</label>
      <div class="p-4 bg-gray-100 rounded-lg border border-gray-300 dark:bg-gray-800 dark:border-gray-700">
        <p class="text-gray-600 dark:text-gray-300">
          <%= @profile.options || "Расскажите о себе" %>
        </p>
      </div>
    </div>

    <div class="mt-8 flex justify-center gap-4 px-8 pb-8">
      <a href="<%= events_path %>" class="rounded-full bg-indigo-500 px-6 py-2 text-sm font-semibold text-white shadow-md hover:bg-indigo-400 dark:bg-indigo-600 dark:hover:bg-indigo-500">
        Мероприятия
      </a>
    </div>
  </div>
</div>

<style>
  @keyframes gradientAnimation {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient-background {
    background-size: 200% 200%;
    animation: gradientAnimation 15s ease infinite;
  }

  /* Bubbles container */
  .bubbles-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Bubble styles */
  .bubble {
    position: absolute;
    background-color: rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    opacity: 0.5;
    pointer-events: none;
    animation-timing-function: linear;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const bubblesContainer = document.getElementById("bubbles-container");

    function createBubble() {
      const bubble = document.createElement("div");
      const size = Math.random() * (150 - 40) + 40; // Random size between 40px and 150px
      const startX = Math.random() * window.innerWidth; // Random horizontal start
      const startY = window.innerHeight + size; // Start below the viewport
      const endX = Math.random() * window.innerWidth; // Random horizontal end position
      const duration = Math.random() * (20 - 10) + 10; // Random duration between 10s and 20s
      const delay = Math.random() * 5; // Random delay before starting animation

      bubble.classList.add("bubble");
      bubble.style.width = `${size}px`;
      bubble.style.height = `${size}px`;
      bubble.style.left = `${startX}px`;
      bubble.style.top = `${startY}px`;
      bubble.style.animation = `bubbleAnimation ${duration}s ${delay}s infinite`;

      bubblesContainer.appendChild(bubble);
    }

    // Create multiple bubbles (adjust the number as needed)
    for (let i = 0; i < 50; i++) {
      createBubble();
    }

    // Keyframes for bubble animation
    const style = document.createElement("style");
    style.innerHTML = `
      @keyframes bubbleAnimation {
        0% {
          transform: translateY(0) translateX(0) scale(1);
        }
        50% {
          transform: translateY(-100vh) translateX(${Math.random() * 100 - 50}vw) scale(1.5);
        }
        100% {
          transform: translateY(100vh) translateX(${Math.random() * 100 - 50}vw) scale(1);
        }
      }
    `;
    document.head.appendChild(style);
  });
</script>
